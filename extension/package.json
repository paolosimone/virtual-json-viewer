{
  "name": "virtual-json-viewer",
  "version": "2.3.0",
  "private": true,
  "type": "module",
  "//": [
    "ESLint is broken for TS7: https://github.com/typescript-eslint/typescript-eslint/issues/10940",
    "When fixed, let's re-add yarn eslint --fix command"
  ],
  "scripts": {
    "format": "yarn prettier --write .",
    "fix": "yarn format && yarn tsc --noEmit",
    "dev": "yarn vite",
    "bump": "yarn upgrade --latest",
    "build:chrome": "yarn tsx vite.build.ts chrome",
    "build:firefox": "yarn tsx vite.build.ts firefox",
    "build:all": "yarn build:chrome && yarn build:firefox",
    "package:chrome": "yarn build:chrome && cd dist/chrome && zip ../virtual-json-viewer-v$npm_package_version-chrome.zip -r .",
    "package:firefox": "yarn build:firefox && cd dist/firefox && zip ../virtual-json-viewer-v$npm_package_version-firefox.zip -r .",
    "package:src": "cd .. && git archive -o extension/dist/virtual-json-viewer-v$npm_package_version-src.zip HEAD README.md extension",
    "package:all": "yarn package:chrome && yarn package:firefox && yarn package:src",
    "clean": "rm -rf dist/*"
  },
  "dependencies": {
    "anchorme": "^3.0.8",
    "json-stable-stringify": "^1.3.0",
    "react": "^19.2.7",
    "react-color": "^2.19.3",
    "react-dom": "^19.2.7",
    "react-window": "^2.2.7",
    "uid": "^2.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/chrome": "^0.2.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-color": "^3.0.13",
    "@types/react-dom": "^19.2.3",
    "@types/tinycolor2": "^1.4.6",
    "@vitejs/plugin-react": "^6.0.3",
    "classnames": "^2.5.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "prettier-plugin-organize-imports": "^4.2.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4"
  }
}
